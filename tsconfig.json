{
  "compilerOptions": {
    "baseUrl": ".",
    "target": "ESNext",
    "useDefineForClassFields": true,
    "lib": ["DOM", "DOM.Iterable", "ESNext"],
    "allowJs": false,
    "skipLibCheck": true,
    "esModuleInterop": false,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "strictNullChecks": false,
    "noImplicitAny": false,
    "forceConsistentCasingInFileNames": true,
    "module": "ESNext",
    "moduleResolution": "Node",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "paths": {
      "@sorare/*": [ "packages/*"],
      "@core/*": [ "packages/core/src/*"],
      "@blockchain/*": [ "packages/blockchain/src/*"],
      "@football/*": [ "packages/football/src/*"],
      "@marketplace/*": [ "packages/marketplace/src/*"],
      "@shared-pages/*": [ "packages/shared-pages/src/*"],
      "@us-sports/*": [ "packages/us-sports/src/*"],
      "@wallet-shared/*": [ "packages/wallet-shared/src/*"],
      "@wallet/*": [ "packages/wallet/src/*"],
      "__generated__/*": [ "packages/core/src/__generated__/*"],
    }
  },
  "include": [
    "lib/lib.es5.d.ts",
    "lib/react.d.ts",
    "packages",
    "src"
  ],
  "references": [{ "path": "./tsconfig.node.json" }]
}
